# Copy this file to .env.local and fill in values from your Supabase project.
# Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — used only on the server side. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Root domain for the app (no protocol, no port).
# In local dev with lvh.me, set this to: lvh.me
# In production, set this to: atlasrewards.app (or whatever your real domain is)
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me
